    "/auth/status": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Get authentication status",
        "responses": {
          "200": {
            "description": "Current authentication state.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "authenticated": {
                      "type": "boolean"
                    },
                    "user": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Start GitHub OAuth login",
        "responses": {
          "302": {
            "description": "Redirects to GitHub for authentication."
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Log out the current user",
        "responses": {
          "302": {
            "description": "Redirects to the home page."
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "githubOAuth": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://github.com/login/oauth/authorize",
            "tokenUrl": "https://github.com/login/oauth/access_token",
            "scopes": {
              "user:email": "Access your GitHub profile"
            }
          }
        }
      }
    },
    "schemas": {
      "Contact": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "64f1c2a0a1b2c3d4e5f67890"
          },
          "firstName": {
            "type": "string",
            "example": "Kalungi"
          },
          "lastName": {
            "type": "string",
            "example": "Isaac"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "kalkatelo@gmail.com"
          },
          "favoriteColor": {
            "type": "string",
            "example": "Blue"
          },
          "birthday": {
            "type": "string",
            "format": "date",
            "example": "1999-05-15"
          }
        }
      },
      "ContactInput": {
        "type": "object",
        "required": [
          "firstName",
          "lastName",
          "email",
          "favoriteColor",
          "birthday"
        ],
        "properties": {
          "firstName": {
            "type": "string",
            "example": "Kalungi"
          },
          "lastName": {
            "type": "string",
            "example": "Isaac"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "kalkatelo@gmail.com"
          },
          "favoriteColor": {
            "type": "string",
            "example": "Blue"
          },
          "birthday": {
            "type": "string",
            "format": "date",
            "example": "1999-05-15"
          }
        }
      },
      "ProfessionalProfile": {
        "type": "object",
        "properties": {
          "professionalName": {
            "type": "string",
            "example": "Kalungi Isaac"
          },
          "nameLink": {
            "type": "object",
            "required": [
              "firstName",
              "url"
            ],
            "properties": {
              "firstName": {
                "type": "string",
                "example": "Kalungi"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "example": "https://github.com/kalungiisaac"
              }
            }
          },
          "base64Image": {
            "type": "string",
            "example": "images/image.jpg"
          },
          "primaryDescription": {
            "type": "string",
            "example": "He is a student at BYU Pathway Worldwide."
          },
          "workDescription1": {
            "type": "string",
            "example": "He is a junior software developer."
          },
          "workDescription2": {
            "type": "string",
            "example": "He is also a professional carpenter."
          },
          "linkTitleText": {
            "type": "string",
            "example": "Follow me:"
          },
          "linkedInLink": {
            "type": "object",
            "required": [
              "link",
              "text"
            ],
            "properties": {
              "link": {
                "type": "string",
                "format": "uri",
                "example": "https://www.linkedin.com/in/kalungiisaac/"
              },
              "text": {
                "type": "string",
                "example": "LinkedIn"
              }
            }
          },
          "githubLink": {
            "type": "object",
            "required": [
              "link",
              "text"
            ],
            "properties": {
              "link": {
                "type": "string",
                "format": "uri",
                "example": "https://github.com/kalungiisaac"
              },
              "text": {
                "type": "string",
                "example": "GitHub"
              }
            }
          },
          "contactText": {
            "type": "string",
            "example": "Ready in case of an opportunity."
          }
        }
      },
      "ProfessionalProfileInput": {
        "type": "object",
        "properties": {
          "professionalName": {
            "type": "string",
            "example": "Kalungi Isaac"
          },
          "nameLink": {
            "type": "object",
            "required": [
              "firstName",
              "url"
            ],
            "properties": {
              "firstName": {
                "type": "string",
                "example": "Kalungi"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "example": "https://github.com/kalungiisaac"
              }
            }
          },
          "base64Image": {
            "type": "string",
            "example": "images/image.jpg"
          },
          "primaryDescription": {
            "type": "string",
            "example": "He is a student at BYU Pathway Worldwide."
          },
          "workDescription1": {
            "type": "string",
            "example": "He is a junior software developer."
          },
          "workDescription2": {
            "type": "string",
            "example": "He is also a professional carpenter."
          },
          "linkTitleText": {
            "type": "string",
            "example": "Follow me:"
          },
          "linkedInLink": {
            "type": "object",
            "required": [
              "link",
              "text"
            ],
            "properties": {
              "link": {
                "type": "string",
                "format": "uri",
                "example": "https://www.linkedin.com/in/kalungiisaac/"
              },
              "text": {
                "type": "string",
                "example": "LinkedIn"
              }
            }
          },
          "githubLink": {
            "type": "object",
            "required": [
              "link",
              "text"
            ],
            "properties": {
              "link": {
                "type": "string",
                "format": "uri",
                "example": "https://github.com/kalungiisaac"
              },
              "text": {
                "type": "string",
                "example": "GitHub"
              }
            }
          },
          "contactText": {
            "type": "string",
            "example": "Ready in case of an opportunity."
          }
        },
        "required": [
          "professionalName",
          "nameLink",
          "base64Image",
          "primaryDescription",
          "workDescription1",
          "workDescription2",
          "linkTitleText",
          "linkedInLink",
          "githubLink",
          "contactText"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
